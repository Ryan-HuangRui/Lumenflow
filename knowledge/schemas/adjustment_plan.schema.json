{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenflow.local/schemas/adjustment_plan.schema.json",
  "title": "Lumenflow Agent Adjustment Plan",
  "type": "object",
  "required": ["schema_version", "source", "variants"],
  "properties": {
    "schema_version": {
      "const": "lumenflow.adjustment_plan.v1"
    },
    "source": {
      "type": "string",
      "description": "Absolute or workspace-relative RAW file path."
    },
    "preview": {
      "type": "string",
      "description": "Preview image path analyzed by the agent."
    },
    "photo_analysis": {
      "type": "object",
      "description": "Agent-readable analysis of subject, light, exposure, color casts, noise, and editing risks.",
      "additionalProperties": true
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Plan revision number. Initial plans should use 1; revised plans increment this value."
    },
    "parent_plan": {
      "type": "string",
      "description": "Previous adjustment plan path when this is a revision after agent review."
    },
    "review_basis": {
      "type": "object",
      "description": "Summary of rendered-output review that caused this revision.",
      "additionalProperties": true
    },
    "lightroom": {
      "type": "object",
      "description": "Optional Lightroom execution metadata shared by all variants.",
      "properties": {
        "photo_id": {
          "type": "string",
          "description": "Lightroom local photo id used by lightroom-cli develop/export commands."
        }
      },
      "additionalProperties": true
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["variant_id", "style_id", "rationale", "adjustments", "composition", "mask_decision"],
        "properties": {
          "variant_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "style_id": {
            "type": "string"
          },
          "style_family_id": {
            "type": "string",
            "description": "Layer 1 style family selected from knowledge/style_families. Required by convention for style-library-driven plans."
          },
          "source_style_card": {
            "type": "string",
            "description": "Layer 2 tutorial-derived style card path when a specific video variant was used."
          },
          "supporting_style_cards": {
            "type": "array",
            "description": "Optional method/workflow cards used as supporting guidance after the visual style was chosen.",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string"
          },
          "adjustments": {
            "type": "object",
            "description": "Concrete per-photo values inferred by the agent. RawTherapee converts these to a temporary PP3 profile; Lightroom maps supported keys to develop settings.",
            "properties": {
              "exposure_compensation": {
                "type": "number"
              },
              "saturation": {
                "type": "number"
              },
              "black": {
                "type": "number"
              },
              "brightness": {
                "type": "number"
              },
              "contrast": {
                "type": "number"
              },
              "highlight_compression": {
                "type": "number"
              },
              "shadow_compression": {
                "type": "number"
              },
              "temperature": {
                "type": "number"
              },
              "green": {
                "type": "number"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "composition": {
            "type": "object",
            "description": "Per-photo agent composition decision. Batching may execute crops, but the judgment must be per photo.",
            "required": ["decision", "reason"],
            "properties": {
              "decision": {
                "enum": ["preserve_existing_crop", "no_crop", "crop", "manual_recommendation"],
                "description": "Explicit framing decision for this photo."
              },
              "reason": {
                "type": "string",
                "description": "Why the framing should be preserved, cropped, or left as a manual recommendation."
              },
              "existing_crop": {
                "type": "object",
                "description": "Existing editor crop metadata when detected; preserve by default unless the user explicitly asks to change it.",
                "additionalProperties": true
              },
              "crop": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "unit": {
                    "enum": ["pixels", "relative", "recommendation"]
                  },
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  },
                  "width": {
                    "type": "number"
                  },
                  "height": {
                    "type": "number"
                  },
                  "left": {
                    "type": "number"
                  },
                  "top": {
                    "type": "number"
                  },
                  "right": {
                    "type": "number"
                  },
                  "bottom": {
                    "type": "number"
                  },
                  "fixed_ratio": {
                    "type": "boolean"
                  },
                  "ratio": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "straighten_degrees": {
                "type": "number"
              },
              "perspective": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          },
          "mask_decision": {
            "type": "object",
            "description": "Per-photo decision about whether local adjustments are needed. Required even when no executable masks are used.",
            "required": ["decision", "reason"],
            "properties": {
              "decision": {
                "enum": ["none", "use_masks", "manual_recommendation"],
                "description": "Whether to execute Lightroom AI masks, skip local edits, or record a manual local-edit recommendation."
              },
              "reason": {
                "type": "string",
                "description": "Why masks are or are not needed for this photo."
              },
              "recommended_masks": {
                "type": "array",
                "description": "Non-executable or future local edits that should be recorded for review.",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          },
          "masks": {
            "type": "array",
            "description": "Optional Lightroom AI masks for local adjustments. Executed only by the Lightroom engine.",
            "items": {
              "type": "object",
              "required": ["type", "rationale"],
              "properties": {
                "type": {
                  "enum": ["subject", "sky", "background", "objects", "people", "landscape"],
                  "description": "Lightroom AI mask selection type."
                },
                "rationale": {
                  "type": "string",
                  "description": "Why this mask is needed for the variant."
                },
                "settings": {
                  "type": "object",
                  "description": "Local Lightroom develop settings for the mask.",
                  "additionalProperties": true
                },
                "adjustments": {
                  "type": "object",
                  "description": "Alias for settings, accepted by the renderer.",
                  "additionalProperties": true
                },
                "preset": {
                  "type": "string",
                  "description": "Named lightroom-cli AI mask preset. Do not combine with settings."
                }
              },
              "additionalProperties": true
            }
          },
          "lightroom": {
            "type": "object",
            "description": "Optional Lightroom metadata for this variant, overriding top-level Lightroom metadata.",
            "properties": {
              "photo_id": {
                "type": "string",
                "description": "Lightroom local photo id used for this variant."
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
